// ========== DATABASE ==========
async function getDb(path = "") {
    const res = await fetch(`${FIREBASE_URL}${path}.json`);
    return res.json();
}

async function patchDb(path, data) {
    const res = await fetch(`${FIREBASE_URL}${path}.json`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
    });
    return res.status;
}

async function deleteDb(path) {
    const res = await fetch(`${FIREBASE_URL}${path}.json`, { method: "DELETE" });
    return res.status;
}

// ========== UTILS ==========
function generateRandomKey() {
    const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
    let result = "";
    for (let i = 0; i < 32; i++) {
        result += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    return result;
}

function calcTimeLeft(startTime, duration) {
    if (duration === -1) return { permanent: true };
    if (!startTime || !duration || startTime === 0) return null;
    const expireAt = startTime + duration;
    const nowSec = Math.floor(Date.now() / 1000);
    const remaining = expireAt - nowSec;
    if (remaining <= 0) return null;
    const days = Math.floor(remaining / 86400);
    const hours = Math.floor((remaining % 86400) / 3600);
    const minutes = Math.floor((remaining % 3600) / 60);
    return { days, hours, minutes, remaining, permanent: false };
}

function isAdmin(member) {
